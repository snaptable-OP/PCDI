# Copy to .env.local and fill in (never commit .env.local).
# These are used by server-only code (Route Handlers / server actions) — not NEXT_PUBLIC_.

# AWS (ap-southeast-2 if using billie-defect-analysis)
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# S3 upload target (name should match the bucket the team created)
AWS_S3_BUCKET=billie-defect-analysis

# S3 addressing: path-style is the default (fewer DNS issues in Node). Use virtual-hosted instead:
# S3_VIRTUAL_HOST_STYLE=true
# Legacy: force path-style off with S3_FORCE_PATH_STYLE=0

# How long the presigned download URL from POST /api/upload-xlsx stays valid (seconds, max 604800 = 7d)
# S3_PRESIGN_TTL_SECONDS=604800

# Billie analysis API (server-side; used by /api/save-excel-content → /api/defect-files/saveExcelContent)
# BILLIE_API_BASE=https://billie-alb-dev-s3.wonderbricks.com:6070
# Optional: if the dev server requires a bearer token
# BILLIE_API_KEY=
# Set to 1 to skip calling the analysis server (local front-end work only; still uploads to S3)
# BILLIE_SKIP_BACKEND_HANDOFF=1

# Skip POST /api/defect-projects — use a random local UUID and continue (no remote project)
# BILLIE_SKIP_DEFECT_PROJECT_CREATE=1
#
# If "Could not reach the analysis server" from your laptop: VPN/firewall, or API down.
# Use both skips below for local UI without Billie (S3 upload still runs unless AWS fails):
# BILLIE_SKIP_DEFECT_PROJECT_CREATE=1
# BILLIE_SKIP_BACKEND_HANDOFF=1
